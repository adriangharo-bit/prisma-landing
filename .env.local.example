# Shopify
SHOPIFY_STORE=acopa-outdoors.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxx

# Codigos validos (uno por gym, separados por coma)
RAFFLE_CODES=PR4X9K,AC7M2R,BV0KJ5,GT9PQR

# Email (Resend)
# FROM_EMAIL must use the exact domain (or subdomain) verified in
# https://resend.com/domains -- check the "Domain" column there, it may
# be a subdomain like send.acopaoutdoors.com rather than the root domain.
RESEND_API_KEY=re_xxxxxxxxxx
FROM_EMAIL=prisma@send.acopaoutdoors.com

# Admin
ADMIN_PASSWORD=clave_secreta_acopa

# Sorteo
RAFFLE_DATE=2026-09-15T20:00:00-06:00
WINNER_COUNT=1

# Vercel KV (se rellenan automaticamente al conectar el store desde Vercel)
KV_REST_API_URL=
KV_REST_API_TOKEN=
